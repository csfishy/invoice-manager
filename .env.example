# Application URLs
FRONTEND_PORT=3000
BACKEND_PORT=8080

# PostgreSQL
POSTGRES_DB=invoice_manager
POSTGRES_USER=invoice_manager
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Backend application
ASPNETCORE_ENVIRONMENT=Development
DATABASE_PROVIDER=Postgres
JWT_ISSUER=invoice-manager
JWT_AUDIENCE=invoice-manager-admin
JWT_SIGNING_KEY=replace_with_a_long_random_secret
JWT_LIFETIME_MINUTES=480
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_now

# Licensing
LICENSE_FILE_PATH=/app/data/license/license.json
LICENSE_FINGERPRINT_SALT=replace_with_machine_fingerprint_salt
LICENSED_PRODUCT_NAME=Invoice Manager

# Storage
UPLOADS_PATH=/app/data/uploads

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
